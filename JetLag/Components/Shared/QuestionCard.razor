@using JetLag.Scripts.Models

<div class="question-card" style="--card-color: @Color">
    <div class="question-card-header">
        @if (!string.IsNullOrEmpty(MainImage))
        {
            <img class="question-card-header-icon" src="@MainImage" alt="@Title icon" />
        }
        <div class="question-card-header-text">
            <span class="question-card-title">@Title</span>
            <span class="question-card-subtitle">@SubTitle</span>
        </div>
    </div>
    <div class="question-card-grid">
        @foreach (var button in Buttons)
        {
            <button class="question-card-btn" @onclick="() => button.InvokeAsync()">
                @if (!string.IsNullOrEmpty(button.ImageSrc))
                {
                    <img src="@button.ImageSrc" alt="" />
                }
            </button>
        }
    </div>
</div>

<style>
    .question-card {
        display: flex;
        flex-direction: column;
        background-color: rgba(15, 23, 42, 0.96);
        border-radius: 10px;
        border: 2px solid var(--card-color, #ffffff);
        overflow: hidden;
        min-width: 160px;
        flex-shrink: 0;
    }

    .question-card-header {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 0.6rem;
        background-color: #1e293b;
        border-bottom: 2px solid var(--card-color, #ffffff);
    }

    .question-card-header-icon {
        width: 24px;
        height: 24px;
        object-fit: contain;
        flex-shrink: 0;
    }

    .question-card-header-text {
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .question-card-title {
        font-family: 'Coolvetica', system-ui, sans-serif;
        font-size: 0.8rem;
        font-weight: 700;
        color: #e5e7eb;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        white-space: nowrap;
    }

    .question-card-subtitle {
        font-size: 0.65rem;
        color: #94a3b8;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        white-space: nowrap;
    }

    .question-card-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 4px;
        padding: 6px;
    }

    .question-card-btn {
        aspect-ratio: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: #1e293b;
        border: 1px solid #334155;
        border-radius: 6px;
        cursor: pointer;
        padding: 4px;
        transition: background-color 0.12s ease, border-color 0.12s ease, transform 0.05s ease;
    }

    .question-card-btn:hover {
        background-color: #293548;
        border-color: var(--card-color, #ffffff);
        transform: scale(1.05);
    }

    .question-card-btn:active {
        transform: scale(0.97);
    }

    .question-card-btn img {
        width: 100%;
        height: 100%;
        object-fit: contain;
    }
</style>

@code {
    [Parameter, EditorRequired]
    public string Title { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public string SubTitle { get; set; } = string.Empty;

    [Parameter]
    public string Color { get; set; } = "#ffffff";

    [Parameter]
    public string MainImage { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public QuestionButtonModel[] Buttons { get; set; } = Array.Empty<QuestionButtonModel>();

    private async Task InvokeCommand(Func<Task> command)
    {
        await command();
    }
}
