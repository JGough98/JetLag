@page "/hider"
@using JetLag.Scripts.Render;
@using JetLag.Scripts.Data;
@using LeafletForBlazor;

@inject IMapRender<RealTimeMap.MapEventArgs, CircleRenderData> CircleRender;


<div class="hider-map-container">
    <RealTimeMap @ref="realTimeMap" height="100vh" width="100vw" Parameters="@parameters"
        OnAfterMapLoaded="HandleMapLoaded" />
</div>

<style>
    .hider-map-container {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        z-index: 1000;
        overflow: hidden;
    }
</style>

@code {
    [SupplyParameterFromQuery(Name = "lat")]
    public double Latitude { get; set; }

    [SupplyParameterFromQuery(Name = "lng")]
    public double Longitude { get; set; }

    [SupplyParameterFromQuery(Name = "zoom")]
    public int ZoomLevel { get; set; }

    private RealTimeMap? realTimeMap;
    private RealTimeMap.LoadParameters parameters = new();

    protected override void OnInitialized()
    {
        if (Latitude == 0 && Longitude == 0)
        {
            Latitude = 51.505;
            Longitude = -0.09;
        }

        if (ZoomLevel == 0)
            ZoomLevel = 13;

        parameters = new RealTimeMap.LoadParameters
        {
            location = new RealTimeMap.Location
            {
                latitude = Latitude,
                longitude = Longitude,
            },
            zoomLevel = ZoomLevel,
            basemap = new RealTimeMap.Basemap
            {
                basemapLayers = new List<RealTimeMap.BasemapLayer>
{
new RealTimeMap.BasemapLayer
{
url = "https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png",
attribution = "&copy; OpenStreetMap",
title = "OpenStreetMap",
detectRetina = true
}
}
            }
        };
    }

    private async Task HandleMapLoaded(RealTimeMap.MapEventArgs args)
    {
        var debugCircleData = new CircleRenderData
        {
            Latitude = Latitude,
            Longitude = Longitude,
            Radius = 500,
            Color = "blue",
            FillColor = "blue",
            Weight = 2,
            Opacity = 0.8,
            FillOpacity = 0.2
        };

        await CircleRender.Render(args, debugCircleData);
    }
}
