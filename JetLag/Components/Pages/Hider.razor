@page "/hider"

<div class="hider-map-container">
    <RealTimeMap @ref="realTimeMap" height="100vh" width="100vw" Parameters="@parameters"
        OnAfterMapLoaded="HandleMapLoaded" />
</div>

<style>
    .hider-map-container {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        z-index: 1000;
        overflow: hidden;
    }
</style>

@code {
    [SupplyParameterFromQuery(Name = "lat")]
    public double Latitude { get; set; }

    [SupplyParameterFromQuery(Name = "lng")]
    public double Longitude { get; set; }

    [SupplyParameterFromQuery(Name = "zoom")]
    public int ZoomLevel { get; set; }

    private RealTimeMap? realTimeMap;
    private RealTimeMap.LoadParameters parameters = new();

    protected override void OnInitialized()
    {
        if (Latitude == 0 && Longitude == 0)
        {
            Latitude = 51.505;
            Longitude = -0.09;
        }

        if (ZoomLevel == 0)
            ZoomLevel = 13;

        parameters = new RealTimeMap.LoadParameters
        {
            location = new RealTimeMap.Location
            {
                latitude = Latitude,
                longitude = Longitude,
            },
            zoomLevel = ZoomLevel,
            basemap = new RealTimeMap.Basemap
            {
                basemapLayers = new List<RealTimeMap.BasemapLayer>
                {
                    new RealTimeMap.BasemapLayer
                    {
                        url = "https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png",
                        attribution = "&copy; OpenStreetMap",
                        title = "OpenStreetMap",
                        detectRetina = true
                    }
                }
            }
        };
    }

    private async Task HandleMapLoaded(RealTimeMap.MapEventArgs args)
    {
        var circlePoints = GenerateCirclePolygon(Latitude, Longitude, 500, 64);
        await args.sender.Geometric.DisplayPolygonsFromArray.add(
        circlePoints,
        new RealTimeMap.PolygonSymbol()
        {
            color = "blue",
            fillColor = "blue",
            weight = 2,
            opacity = 0.8,
            fillOpacity = 0.2
        });
    }

    private static List<double[]> GenerateCirclePolygon(double centerLat, double centerLng, double radiusMeters, int points = 64)
    {
        const double earthRadius = 6371000;
        var polygon = new List<double[]>();
        for (int i = 0; i <= points; i++)
        {
            double angle = 2 * Math.PI * i / points;
            double latOffset = radiusMeters / earthRadius * (180.0 / Math.PI);
            double lngOffset = radiusMeters / earthRadius * (180.0 / Math.PI) / Math.Cos(centerLat * Math.PI / 180.0);
            polygon.Add(new double[]
            {
                centerLat + latOffset * Math.Sin(angle),
                centerLng + lngOffset * Math.Cos(angle)
            });
        }
        return polygon;
    }
}
