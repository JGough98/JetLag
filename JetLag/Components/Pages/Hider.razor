@page "/hider"

@using JetLag.Scripts.Render
@using JetLag.Scripts.Models

@inject IMapRender mapRender


<div class="hider-map-container">
	<MapLibre @ref="_map" Options="_parameters" OnLoad="HandleMapLoaded" Width="100%" Height="100%" />
</div>

<QuestionsMenu Cards="_cards" />

<style>
	.hider-map-container {
		position: fixed;
		top: 0;
		left: 0;
		width: 100vw;
		height: 100vh;
		z-index: 1000;
		overflow: hidden;
	}
</style>

