@page "/hider"

@using JetLag.Scripts.Factory.Interface
@using JetLag.Scripts.Models
@using JetLag.Scripts.Render
@using Community.Blazor.MapLibre.Models.Event

@inject IFactory<IReadOnlyList<QuestionCardModel>, QuestionCardFactoryInput> cardFactory
@inject MapRender mapRender


<div class="hider-map-container">
	<MapLibre @ref="_map" Options="_parameters" OnLoad="HandleMapLoaded" Width="100%" Height="100%" />
</div>

<QuestionsMenu Cards="_cards.ToArray()" />

<style>
	.hider-map-container {
		position: fixed;
		top: 0;
		left: 0;
		width: 100vw;
		height: 100vh;
		z-index: 1000;
		overflow: hidden;
	}
</style>

@code {
	[SupplyParameterFromQuery(Name = "lat")]
	public double Latitude { get; set; }

	[SupplyParameterFromQuery(Name = "lng")]
	public double Longitude { get; set; }

	[SupplyParameterFromQuery(Name = "zoom")]
	public int ZoomLevel { get; set; }

	private MapLibre? _map;
	private MapOptions _parameters = new();

	private IReadOnlyList<QuestionCardModel> _cards;

	private bool _radarActive = false;
	private Listener? _mouseMoveListener;
	private Listener? _mapClickListener;


	protected override void OnInitialized()
	{
		_cards = cardFactory.Create(new QuestionCardFactoryInput(this, HandleQuestionButton));

		if (Latitude == 0 && Longitude == 0)
		{
			Latitude = 51.505;
			Longitude = -0.09;
		}

		if (ZoomLevel == 0)
			ZoomLevel = 13;

		_parameters = new MapOptions
		{
			Center = new LngLat(Longitude, Latitude),
			Zoom = ZoomLevel,
			Style = "https://tiles.openfreemap.org/styles/liberty",
			MinZoom = 2
		};
	}

	private async Task HandleMapLoaded(EventArgs args)
	{
		await mapRender.OutOfBounds.RenderStraightLine(_map!, Latitude, Longitude, 5);
		await mapRender.Overlay.RenderCircle(_map!, Latitude, Longitude, 600);
	}

	private async Task HandleQuestionButton(QuestionButtonEventArgs args)
	{
		if (args.Title == "RADAR")
			await ActivateRadar();
	}

	private async Task ActivateRadar()
	{
		if (_radarActive || _map is null) return;
		_radarActive = true;

		_mouseMoveListener = await _map.AddAsyncListener<MapMouseEvent>(
			"mousemove",
			async (e) =>
			{
				await mapRender.Overlay.ReplaceCircle(_map, e.LngLat.Latitude, e.LngLat.Longitude, 100);
			});

		_mapClickListener = await _map.AddAsyncListener<MapMouseEvent>(
			"click",
			async (e) =>
			{
				await mapRender.OutOfBounds.RenderCircle(_map, e.LngLat.Latitude, e.LngLat.Longitude, 100);
				await mapRender.Overlay.Clear(_map);
				await DeactivateRadar();
			});
	}

	private Task DeactivateRadar()
	{
		_radarActive = false;
		_mouseMoveListener = null;
		_mapClickListener = null;
		return Task.CompletedTask;
	}
}
