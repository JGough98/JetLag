@page "/"
@using JetLag.Resources
@using JetLag.Scripts.Utility

@inject IStringLocalizer<TextConstants> L


<PageTitle>@L["AppName"] - @L["JoinLobby"]</PageTitle>

<div class="join-lobby-page">
    <div class="join-lobby-card">
        <h1 class="join-lobby-title">@L["AppName"]</h1>

        <div class="join-lobby-form-group">
            <input id="playerName" class="join-lobby-input" placeholder='@L["EnterName"]' @bind="playerName" />
        </div>

        <div class="join-lobby-actions">
            <button class="join-lobby-button join-lobby-button-primary" @onclick="OnPlayClicked"
                disabled="@RejectPlayerName(playerName)">
                @L["Play"]
            </button>
            <button class="join-lobby-button join-lobby-button-secondary" @onclick="OnCreatePrivateRoomClicked"
                disabled="@RejectPlayerName(playerName)">
                @L["CreatePrivateRoom"]
            </button>
        </div>
    </div>
</div>

@code {
    private string playerName = string.Empty;

    private static readonly HashSet<string> inappropriateNames =
    ReadUtility.ReadRecourseTextFile("InappropriateNames").ToHashSet();


    /// <summary>
    /// Transitions to a public lobby.
    /// <summary>
    private void OnPlayClicked()
    {
        // TODO: Implement navigation to lobby / game
    }

    /// <summary>
    /// Transitions to a private lobby.
    /// <summary>
    private void OnCreatePrivateRoomClicked()
    {
        // TODO: Implement create private room flow
    }

    /// <summary>
    /// Rejects a player name if it is empty or inappropriate.
    /// </summary>
    /// <param name="name">The name to check.</param>
    /// <returns>True if the name is rejected, false otherwise.</returns>
    /// <summary>
    private bool RejectPlayerName(string name)
    => string.IsNullOrWhiteSpace(name) || IsInappropriateName(name);

    /// <summary>
    /// Checks if a name is inappropriate.
    /// </summary>
    /// <param name="name">The name to check.</param>
    /// <returns>True if the name is inappropriate, false otherwise.</returns>
    /// <summary>
    private bool IsInappropriateName(string name)
    {
        // TODO-SERVER : Move this to the sever side, on the server call another comerical API to check if the name is
        // inappropriate.
        name = name.ToLower();

        foreach (var inappropriateName in inappropriateNames)
        {
            if (name.Contains(inappropriateName))
                return true;
        }

        return false;
    }
}
